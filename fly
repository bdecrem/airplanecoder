#!/bin/bash
# Airplane Coder launcher — runs in your current directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"

case "${1:-}" in
    check) cd "$SCRIPT_DIR" && cargo check ;;
    test)  cd "$SCRIPT_DIR" && cargo test ;;
    build) cd "$SCRIPT_DIR" && cargo build ;;
    *)     cargo run --manifest-path "$SCRIPT_DIR/Cargo.toml" -- "$@" ;;
esac
